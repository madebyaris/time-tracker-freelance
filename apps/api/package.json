{
  "name": "@ttf/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.node.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.node.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "cf:check": "pnpm --filter @ttf/web build && wrangler deploy -c ../../infra/wrangler/wrangler.jsonc --env staging --dry-run",
    "cf:types": "wrangler types -c ../../infra/wrangler/wrangler.jsonc src/worker-configuration.d.ts",
    "cf:types:check": "wrangler types --check -c ../../infra/wrangler/wrangler.jsonc src/worker-configuration.d.ts",
    "cf:dev": "pnpm --filter @ttf/web build && wrangler dev -c ../../infra/wrangler/wrangler.jsonc --local --env-file ../../.dev.vars",
    "cf:migrate:local": "wrangler d1 migrations apply tickr-local --local -c ../../infra/wrangler/wrangler.jsonc",
    "cf:migrate:staging": "wrangler d1 migrations apply tickr-staging --remote -c ../../infra/wrangler/wrangler.jsonc --env staging",
    "cf:deploy:dry": "pnpm --filter @ttf/web build && wrangler deploy -c ../../infra/wrangler/wrangler.jsonc --env staging --dry-run",
    "cf:deploy:staging": "pnpm --filter @ttf/web build && wrangler deploy -c ../../infra/wrangler/wrangler.jsonc --env staging",
    "cf:tail:staging": "wrangler tail -c ../../infra/wrangler/wrangler.jsonc --env staging",
    "cf:deploy": "pnpm run cf:deploy:staging"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@ttf/db": "workspace:*",
    "@ttf/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.3",
    "jose": "^5.9.4",
    "nanoid": "^5.0.9",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "wrangler": "^4.85.0"
  }
}
