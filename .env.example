# API (Node)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/timetracker
JWT_SECRET=change-me-to-at-least-32-chars-please-abc
PORT=8787
CORS_ORIGIN=http://localhost:1420,http://localhost:5173
REGISTRATION_MODE=open

# Optional: Cloudflare Worker/D1 (copy to .dev.vars for wrangler dev)
# JWT_SECRET should be at least 32 random bytes, e.g. `openssl rand -hex 32`.
# REGISTRATION_MODE can be open, first-user, or disabled.
